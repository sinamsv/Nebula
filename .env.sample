DISCORD_TOKEN=

# --- AI Provider Configuration ---
# AI_PROVIDER selects which AI backend Nebula uses. Valid values: openai,
# anthropic, google, xai, openrouter, groq. AI_API_KEY is your API key for
# whichever provider you chose. AI_MODEL is the model string for that
# provider (e.g. "gpt-5.2" for openai, "claude-sonnet-4-6" for anthropic,
# "gemini-3.1-pro-preview" for google, "grok-4.3" for xai, a
# "provider/model" slug like "anthropic/claude-sonnet-4" for openrouter,
# or "llama-3.3-70b-versatile" for groq).
#
# openai, anthropic, and google use their own official SDKs and know their
# own default API endpoint, so you don't need to set a base URL for them
# unless you're pointing at a proxy or self-hosted gateway (see
# ai/config.json's "base_url" field for each provider, normally left null).
# xai, openrouter, and groq have no dedicated SDK — they're accessed as
# OpenAI-compatible endpoints, and their base_url is already filled in for
# you in ai/config.json.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=google/gemini-2.0-flash-001 #you can change it

# --- Deprecated (still works, but no longer recommended) ---
# OPENAI_API_KEY / OPENAI_BASE_URL were the only way to configure the AI
# backend before AI_PROVIDER/AI_API_KEY existed above. They're still
# honored if you have them set (OPENAI_BASE_URL in particular is still
# used to override the endpoint, e.g. if you were pointing it at Gemini's
# OpenAI-compatible endpoint), but new setups should use AI_PROVIDER +
# AI_API_KEY instead — this pair may be removed in a future release.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Telegram (optional second adapter) ---
# Get a token from @BotFather on Telegram (https://t.me/BotFather):
# /newbot, follow the prompts, and it'll give you a token that looks
# like 123456789:AAExampleTokenTextGoesHere.
#
# Leave this blank to run Discord only. Set DISCORD_TOKEN blank instead
# to run Telegram only. Set both to run both adapters concurrently --
# they share the same Nebula accounts, memory, and coin balances (see
# core/database.py's platform_identities table and /sync on Discord for
# how to link one Nebula account across both platforms).
TELEGRAM_BOT_TOKEN=

# --- Port Settings (Railway / PaaS aware, since v1.6.1) ---
# PORT is the PaaS convention (Railway, Render, Fly.io, Heroku, ...):
# these platforms inject this env var themselves and only route public
# traffic to it. When set, this is what Next.js (the single public-
# facing process in this deployment) binds to -- see main.py's
# _resolve_public_port(). Leave this UNSET for local/non-PaaS runs;
# FRONTEND_PORT below is used instead. Do NOT set this yourself for
# local development -- Railway (and similar platforms) sets it
# automatically at deploy time, you never need to type a value here.
# PORT=

# FRONTEND_PORT: local/non-PaaS fallback port for the Next.js web
# frontend, used only when PORT is not set (i.e. not running on
# Railway/similar). Ignored on Railway itself, since PORT takes
# priority whenever it's present.
FRONTEND_PORT=8080

# BACKEND_PORT: the port FastAPI listens on. Since v1.6.1 this is an
# INTERNAL-ONLY port -- FastAPI binds to 127.0.0.1:BACKEND_PORT and is
# NEVER exposed publicly by itself, on Railway or otherwise. Next.js
# proxies every /api/v1/* request to it internally over localhost (see
# web_frontend/next.config.mjs's rewrites()). This is what lets a
# single Railway service / single public port serve both the web UI
# and the API, without needing a second Railway service or an nginx
# layer in front of both.
BACKEND_PORT=8000

# --- Web panel (FastAPI backend + Next.js frontend) ---
# The web adapter is mandatory (always starts, no toggle). On Railway
# specifically, it is served as ONE public-facing process (Next.js, on
# PORT) with FastAPI running invisibly behind it on BACKEND_PORT --
# see main.py and web_frontend/next.config.mjs for the full mechanics.

# The Next.js frontend's own PUBLIC-FACING origin -- used as the
# redirect target after a successful Google OAuth callback, and
# anywhere else that needs to construct an absolute link back to the
# web panel. On Railway, set this to your actual deployed domain once
# you know it, e.g. https://your-app-name.up.railway.app (Railway only
# assigns this AFTER your first deploy, so it's fine to deploy once
# with the localhost placeholder below, then come back, set the real
# value, and redeploy). Note this is unrelated to whether the API
# itself works: same-origin API calls go through Next.js's rewrites()
# proxy regardless of what this is set to -- this var is specifically
# for OAuth redirects and other absolute links, not for routing API
# traffic.
WEB_FRONTEND_URL=http://localhost:8080

# --- Frontend Public Variables ---
# NEXT_PUBLIC_API_BASE_URL: where the BROWSER should send API calls.
# Since v1.6.1, this should normally be a RELATIVE path ("/api/v1"),
# NOT a full "http://host:port" URL. Next.js's own rewrites() proxy
# (web_frontend/next.config.mjs) forwards every /api/v1/* request to
# FastAPI internally, so the browser only ever needs to know about
# Next.js's own origin -- whatever that happens to be (localhost:8080
# locally, your Railway domain in production) -- with no separate
# backend host/port to configure or keep in sync as domains change.
# Only override this with a full absolute URL if you're intentionally
# running the frontend and backend as fully separate, unproxied
# services (e.g. frontend deployed on Vercel, backend deployed
# elsewhere) -- in that case you're opting back into needing CORS
# configured correctly on the backend (see web_backend/app.py's
# WEB_FRONTEND_URL-based CORS origin).
NEXT_PUBLIC_API_BASE_URL=/api/v1

# JWT_SECRET signs/validates the web adapter's login tokens. Generate a
# random one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Treat this like a root password: long, random, never shared, never
# committed. Rotating it invalidates every currently-logged-in web
# session (users just log in again -- no other side effects).
JWT_SECRET=

# OAUTH_TOKEN_ENCRYPTION_KEY encrypts Google OAuth access/refresh
# tokens at rest in the oauth_connections table (see core/crypto.py --
# this is real reversible encryption, NOT hashing, since these tokens
# must be recoverable in plaintext to actually call Google's APIs).
# Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key permanently loses the ability to decrypt any already-
# stored Google tokens (users would simply need to reconnect Google --
# not catastrophic, but avoid losing it carelessly).
OAUTH_TOKEN_ENCRYPTION_KEY=

# --- Google OAuth (infrastructure only this release -- lets a user
# connect a Google account via the web panel; NOT wired to any actual
# Google Sheets/Calendar tool yet, and entirely optional/skippable --
# Nebula works fully without ever setting these). Get these from the
# Google Cloud Console (https://console.cloud.google.com/apis/credentials):
# create an OAuth 2.0 Client ID (type: Web application), and add
# GOOGLE_OAUTH_REDIRECT_URI below as an Authorized redirect URI there.
# On Railway, this must point at your PUBLIC domain (once known after
# first deploy) -- e.g.
# https://your-app-name.up.railway.app/api/v1/auth/google/callback --
# even though FastAPI itself is internal-only, this specific URL is
# what GOOGLE redirects the user's browser to, and the browser only
# ever sees the public Next.js origin (which proxies it through to
# FastAPI via rewrites(), same as any other /api/v1/* call).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# --- Admin Bootstrap ---
# One-time, single-use key used to claim the FIRST Nebula admin account.
# Whoever runs `/signup` with this exact key (as the bootstrap_key
# parameter, on Discord, Telegram, OR the web panel's signup form) becomes
# Nebula's first admin, auto-approved. The key is consumed on first
# successful use — after that, /add_admin (Discord) or the web panel's
# admin review page is the only way to create/approve more admins.
#
# Generate a random 256-character key with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(192))"
# (token_urlsafe(192) produces exactly 256 characters.)
#
# Treat this like a root password: set it, use it once, never share it,
# never commit it.
ADMIN_BOOTSTRAP_KEY=

# --- Development ---
# Set to sync slash commands instantly to one test server instead of
# waiting up to an hour for global propagation. Discord only --
# Telegram commands take effect immediately, no propagation delay.
DEV_GUILD_ID=

# --- Web Search Configuration ---
# SEARCH_PROVIDER selects which search backend Nebula uses. Both providers'
# credentials can be filled in at the same time; only the selected one is
# actually used. If the selected provider's credentials are missing, the
# entire search tool is disabled (no automatic fallback to the other one).
# Valid values: google, tavily (default: google)
SEARCH_PROVIDER=tavily

# Google Custom Search (used when SEARCH_PROVIDER=google)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Tavily (used when SEARCH_PROVIDER=tavily) - an AI-native search API,
# get a key at https://app.tavily.com/
TAVILY_API_KEY=
