# Copy this file to .env.local (for local dev) and fill in as needed.
# Next.js automatically loads .env.local — no extra setup required.
#
# NEXT_PUBLIC_API_BASE_URL: where the Nebula backend (FastAPI) is
# reachable from the BROWSER (not from the server -- this value gets
# baked into the JavaScript that runs in the user's browser, since it's
# prefixed with NEXT_PUBLIC_). Must include the /api/v1 path.
#
# Default matches the backend's confirmed port (50051). Only change
# this if you deploy the backend somewhere other than localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:50051/api/v1
